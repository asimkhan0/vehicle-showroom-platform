# --- Dev Supabase (npm run dev) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- E2E Supabase (npm run test:e2e — ignored by Next.js, used by Playwright) ---
E2E_SUPABASE_URL=
E2E_SUPABASE_ANON_KEY=
E2E_SUPABASE_SERVICE_ROLE_KEY=
# Optional safety rail: e2e refuses to run if E2E_SUPABASE_URL doesn't contain this ref.
E2E_SUPABASE_PROJECT_REF=

# --- App ---
NEXT_PUBLIC_PLATFORM_HOST=localhost:3000

# --- Vercel (custom domains — server-only except EDGE_CONFIG for edge reads) ---
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
# Required when the project lives under a Vercel team (not a personal account).
VERCEL_TEAM_ID=
# Connection string from Vercel → Storage → Edge Config → Connect.
EDGE_CONFIG=
# Edge Config store id (for API writes when syncing hostname → slug).
EDGE_CONFIG_ID=

# --- Cron (optional; protects /api/cron/verify-domains) ---
CRON_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM=Showroom <onboarding@resend.dev>
RESEND_REPLY_TO=
